{
  "provider": "openrouter",
  "label": "OpenRouter",
  "defaults": {
    "features": {
      "systemInstruction": true
    },
    "tools": {},
    "attachments": {
      "enabled": true,
      "allowRemoteUpload": false,
      "allowedMimes": [],
      "maxInlineFileSize": 10485760
    },
    "parameters": {
      "temperature": {
        "ui": {
          "type": "number",
          "label": "Temperature",
          "range": { "min": 0, "max": 2, "step": 0.05 }
        },
        "api": { "path": "temperature" }
      },
      "topP": {
        "ui": {
          "type": "number",
          "label": "Top P",
          "range": { "min": 0, "max": 1, "step": 0.01 }
        },
        "api": { "path": "top_p" }
      },
      "topK": {
        "ui": {
          "type": "integer",
          "label": "Top K",
          "range": { "min": 0, "max": 500, "step": 1 }
        },
        "api": { "path": "top_k" }
      },
      "reasoningEffort": {
        "ui": {
          "type": "enum",
          "label": "Reasoning Effort",
          "options": [
            { "label": "Off", "value": "none" },
            { "label": "Minimal", "value": "minimal" },
            { "label": "Low", "value": "low" },
            { "label": "Medium", "value": "medium" },
            { "label": "High", "value": "high" },
            { "label": "xHigh", "value": "xhigh" }
          ]
        },
        "api": { "transform": "openrouterReasoning" }
      }
    }
  },
  "models": []
}
