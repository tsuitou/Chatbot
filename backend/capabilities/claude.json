{
  "provider": "claude",
  "label": "Anthropic Claude",
  "defaults": {
    "features": {
      "systemInstruction": true
    },
    "tools": {},
    "attachments": {
      "enabled": true,
      "allowRemoteUpload": false,
      "allowedMimes": [
        "text/plain",
        "application/pdf",
        "image/png",
        "image/jpeg",
        "image/gif",
        "image/webp"
      ],
      "maxInlineFileSize": 10485760
    },
    "parameters": {
      "temperature": {
        "ui": {
          "type": "number",
          "label": "Temperature",
          "range": { "min": 0, "max": 1, "step": 0.05 }
        },
        "api": { "path": "temperature" }
      },
      "topP": {
        "ui": {
          "type": "number",
          "label": "Top P",
          "range": { "min": 0, "max": 1, "step": 0.01 }
        },
        "api": { "path": "top_p" }
      },
      "maxOutputTokens": {
        "default": 16000,
        "ui": {
          "type": "integer",
          "label": "Max Output Tokens",
          "range": { "min": 1, "max": 16000 }
        },
        "api": { "path": "max_tokens" }
      }
    }
  },
  "models": [
    {
      "modelQuery": "claude-opus-4-7",
      "features": {
        "adaptiveThinking": true,
        "extendedThinking": false
      },
      "parameters": {
        "temperature": null,
        "topP": null,
        "maxOutputTokens": {
          "default": 128000,
          "ui": { "range": { "min": 1, "max": 128000 } }
        },
        "thinkingBudget": {
          "default": -1,
          "ui": {
            "type": "integer",
            "label": "Thinking Mode",
            "specialValues": [
              { "label": "Disabled", "value": 0 },
              { "label": "Adaptive", "value": -1 }
            ]
          },
          "api": { "transform": "claudeThinking" }
        }
      }
    },
    {
      "modelQuery": "claude-sonnet-4-6",
      "features": {
        "adaptiveThinking": true,
        "extendedThinking": true
      },
      "parameters": {
        "maxOutputTokens": {
          "default": 64000,
          "ui": { "range": { "min": 1, "max": 64000 } }
        },
        "thinkingBudget": {
          "default": 32000,
          "ui": {
            "type": "integer",
            "label": "Thinking Budget",
            "range": { "min": 1024, "max": 32000, "step": 256 },
            "specialValues": [
              { "label": "Disabled", "value": 0 },
              { "label": "Adaptive", "value": -1 }
            ]
          },
          "api": { "transform": "claudeThinking" }
        }
      }
    },
    {
      "modelQuery": "claude-haiku-4-5",
      "features": {
        "adaptiveThinking": false,
        "extendedThinking": true
      },
      "parameters": {
        "maxOutputTokens": {
