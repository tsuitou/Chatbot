{
  "provider": "gemini",
  "label": "Google Gemini",
  "api": {
    "parameterMap": {
      "temperature": "temperature",
      "topP": "topP",
      "topK": "topK",
      "maxOutputTokens": "maxOutputTokens"
    }
  },
  "defaults": {
    "features": {
      "systemInstruction": true
    },
    "tools": {
      "urlContext": {
        "enabled": true,
        "label": "URL Context",
        "icon": "link"
      },
      "grounding": {
        "enabled": true,
        "label": "Search Grounding",
        "icon": "search"
      },
      "codeExecution": {
        "enabled": true,
        "label": "Code Execution",
        "icon": "code"
      }
    },
    "attachments": {
      "enabled": true,
      "allowRemoteUpload": true,
      "allowedMimes": null,
      "maxInlineFileSize": 10485760
    },
    "parameters": {
      "temperature": {
        "type": "number",
        "label": "Temperature",
        "range": { "min": 0, "max": 2, "step": 0.1 }
      },
      "topP": {
        "type": "number",
        "label": "Top P",
        "range": { "min": 0, "max": 1, "step": 0.01 }
      }
    }
  },
  "models": [
    {
      "modelQuery": "image",
      "features": {
        "systemInstruction": false,
        "imageConfigParams": ["aspectRatio", "imageSize", "personGeneration"]
      },
      "tools": {
        "urlContext": { "enabled": false },
        "grounding": { "enabled": false },
        "codeExecution": { "enabled": false }
      },
      "parameters": {
        "temperature": null,
        "topP": null,
        "aspectRatio": {
          "type": "enum",
          "label": "Aspect Ratio",
          "options": [
            { "label": "1:1",  "value": "1:1"  },
            { "label": "3:4",  "value": "3:4"  },
            { "label": "4:3",  "value": "4:3"  },
            { "label": "9:16", "value": "9:16" },
            { "label": "16:9", "value": "16:9" },
            { "label": "2:3",  "value": "2:3"  },
            { "label": "3:2",  "value": "3:2"  },
            { "label": "21:9", "value": "21:9" }
          ]
        },
        "imageSize": {
          "type": "enum",
          "label": "Image Size",
          "options": [
            { "label": "1K (Default)", "value": "1K" },
            { "label": "2K",           "value": "2K" },
            { "label": "4K",           "value": "4K" }
          ]
        },
        "personGeneration": {
          "type": "enum",
          "label": "Person Generation",
          "options": [
            { "label": "Allow Adults", "value": "ALLOW_ADULT" },
            { "label": "Allow All",    "value": "ALLOW_ALL"   },
            { "label": "Block All",    "value": "ALLOW_NONE"  }
          ]
        }
      }
    },
    {
      "modelQuery": "3.5-flash",
      "features": {
        "includeThoughts": true
      },
      "parameters": {
        "thinkingLevel": {
          "type": "enum",
          "label": "Thinking Level",
          "options": [
            { "label": "Minimal", "value": "minimal" },
            { "label": "Low", "value": "low" },
            { "label": "Medium", "value": "medium" },
            { "label": "High", "value": "high" }
          ]
        }
      }
    },
    {
      "modelQuery": "3.1-pro",
      "features": {
        "includeThoughts": true
      },
      "parameters": {
        "thinkingLevel": {
          "type": "enum",
          "label": "Thinking Level",
          "options": [
            { "label": "Low", "value": "low" },
            { "label": "Medium", "value": "medium" },
            { "label": "High", "value": "high" }
          ]
        }
      }
    },
    {
      "modelQuery": "3-pro",
      "features": {
        "includeThoughts": true
      },
      "parameters": {
        "thinkingLevel": {
          "type": "enum",
          "label": "Thinking Level",
          "options": [
            { "label": "Low", "value": "low" },
            { "label": "Medium", "value": "medium" },
            { "label": "High", "value": "high" }
          ]
        }
      }
    },
    {
      "modelQuery": "2.5-pro",
      "features": {
        "includeThoughts": true
      },
      "parameters": {
        "thinkingBudget": {
          "type": "integer",
          "label": "Thinking Budget",
          "range": { "min": 128, "max": 32768 },
          "specialValues": [
            { "label": "Auto", "value": -1 }
          ]
        }
      }
    },
    {
      "modelQuery": "2.5-flash-lite",
      "features": {
        "includeThoughts": true
      },
      "parameters": {
        "thinkingBudget": {
          "type": "integer",
          "label": "Thinking Budget",
          "range": { "min": 512, "max": 24576 },
          "specialValues": [
            { "label": "Auto", "value": -1 },
            { "label": "Off", "value": 0 }
          ]
        }
      }
    },
    {
      "modelQuery": "2.5-flash",
      "features": {
        "includeThoughts": true
      },
      "parameters": {
        "thinkingBudget": {
          "type": "integer",
          "label": "Thinking Budget",
          "range": { "min": 1, "max": 24576 },
          "specialValues": [
            { "label": "Auto", "value": -1 },
            { "label": "Off", "value": 0 }
          ]
        }
      }
    }
  ]
}
