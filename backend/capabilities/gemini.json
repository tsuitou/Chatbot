{
  "provider": "gemini",
  "label": "Google Gemini",
  "defaults": {
    "features": {
      "systemInstruction": true,
      "includeServerSideToolInvocations": false
    },
    "tools": {
      "urlContext": {
        "enabled": true,
        "label": "URL Context",
        "icon": "link"
      },
      "grounding": {
        "enabled": true,
        "label": "Search Grounding",
        "icon": "search"
      },
      "codeExecution": {
        "enabled": true,
        "label": "Code Execution",
        "icon": "code"
      }
    },
    "attachments": {
      "enabled": true,
      "allowRemoteUpload": true,
      "allowedMimes": null,
      "maxInlineFileSize": 10485760
    },
    "parameters": {
      "temperature": {
        "ui": {
          "type": "number",
          "label": "Temperature",
          "range": { "min": 0, "max": 2, "step": 0.1 }
        },
        "api": { "path": "temperature" }
      },
      "topP": {
        "ui": {
          "type": "number",
          "label": "Top P",
          "range": { "min": 0, "max": 1, "step": 0.01 }
        },
        "api": { "path": "topP" }
      },
      "maxOutputTokens": {
        "ui": {
          "type": "integer",
          "label": "Max Output Tokens"
        },
        "api": { "path": "maxOutputTokens" }
      }
    }
  },
  "models": [
    {
      "modelQuery": "image",
      "priority": 1,
      "features": {
        "systemInstruction": false
      },
      "tools": {
        "urlContext": { "enabled": false },
        "grounding": { "enabled": false },
        "codeExecution": { "enabled": false }
      },
      "parameters": {
        "temperature": null,
        "topP": null,
        "maxOutputTokens": null,
        "aspectRatio": {
          "ui": {
            "type": "enum",
            "label": "Aspect Ratio",
            "options": [
              { "label": "1:1",  "value": "1:1"  },
              { "label": "3:4",  "value": "3:4"  },
              { "label": "4:3",  "value": "4:3"  },
              { "label": "9:16", "value": "9:16" },
              { "label": "16:9", "value": "16:9" },
              { "label": "2:3",  "value": "2:3"  },
              { "label": "3:2",  "value": "3:2"  },
              { "label": "21:9", "value": "21:9" }
            ]
          },
          "api": { "path": "imageConfig.aspectRatio" }
        },
        "imageSize": {
          "ui": {
            "type": "enum",
            "label": "Image Size",
            "options": [
              { "label": "1K (Default)", "value": "1K" },
              { "label": "2K",           "value": "2K" },
              { "label": "4K",           "value": "4K" }
            ]
          },
          "api": { "path": "imageConfig.imageSize" }
        },
        "personGeneration": {
          "ui": {
            "type": "enum",
            "label": "Person Generation",
            "options": [
              { "label": "Allow Adults", "value": "ALLOW_ADULT" },
              { "label": "Allow All",    "value": "ALLOW_ALL"   },
              { "label": "Block All",    "value": "ALLOW_NONE"  }
            ]
          },
          "api": { "path": "imageConfig.personGeneration" }
        }
      }
    },
    {
      "modelQuery": "3.5-flash",
      "features": {
        "includeServerSideToolInvocations": true
      },
      "parameters": {
        "thinkingLevel": {
          "ui": {
            "type": "enum",
            "label": "Thinking Level",
            "options": [
              { "label": "Minimal", "value": "minimal" },
              { "label": "Low", "value": "low" },
              { "label": "Medium", "value": "medium" },
              { "label": "High", "value": "high" }
            ]
          },
          "api": { "path": "thinkingConfig.thinkingLevel" }
        },
        "includeThoughts": {
          "ui": { "type": "boolean", "label": "Include Thoughts" },
          "api": { "path": "thinkingConfig.includeThoughts" }
        }
      }
    },
    {
      "modelQuery": "3.1-pro",
      "parameters": {
        "thinkingLevel": {
          "ui": {
            "type": "enum",
            "label": "Thinking Level",
            "options": [
              { "label": "Low", "value": "low" },
              { "label": "Medium", "value": "medium" },
              { "label": "High", "value": "high" }
            ]
          },
          "api": { "path": "thinkingConfig.thinkingLevel" }
        },
        "includeThoughts": {
          "ui": { "type": "boolean", "label": "Include Thoughts" },
          "api": { "path": "thinkingConfig.includeThoughts" }
        }
      }
    },
    {
      "modelQuery": "3-pro",
      "parameters": {
        "thinkingLevel": {
          "ui": {
            "type": "enum",
            "label": "Thinking Level",
            "options": [
              { "label": "Low", "value": "low" },
              { "label": "Medium", "value": "medium" },
              { "label": "High", "value": "high" }
            ]
          },
          "api": { "path": "thinkingConfig.thinkingLevel" }
        },
        "includeThoughts": {
          "ui": { "type": "boolean", "label": "Include Thoughts" },
          "api": { "path": "thinkingConfig.includeThoughts" }
        }
      }
    },
    {
      "modelQuery": "2.5-pro",
      "parameters": {
        "thinkingBudget": {
          "ui": {
            "type": "integer",
            "label": "Thinking Budget",
            "range": { "min": 128, "max": 32768 },
            "specialValues": [
              { "label": "Auto", "value": -1 }
            ]
          },
          "api": { "path": "thinkingConfig.thinkingBudget" }
        },
        "includeThoughts": {
          "ui": { "type": "boolean", "label": "Include Thoughts" },
          "api": { "path": "thinkingConfig.includeThoughts" }
        }
      }
    },
    {
      "modelQuery": "2.5-flash-lite",
      "parameters": {
        "thinkingBudget": {
          "ui": {
            "type": "integer",
            "label": "Thinking Budget",
            "range": { "min": 512, "max": 24576 },
            "specialValues": [
              { "label": "Auto", "value": -1 },
              { "label": "Off", "value": 0 }
            ]
          },
          "api": { "path": "thinkingConfig.thinkingBudget" }
        },
        "includeThoughts": {
          "ui": { "type": "boolean", "label": "Include Thoughts" },
          "api": { "path": "thinkingConfig.includeThoughts" }
        }
      }
    },
    {
      "modelQuery": "2.5-flash",
      "parameters": {
        "thinkingBudget": {
          "ui": {
            "type": "integer",
            "label": "Thinking Budget",
            "range": { "min": 1, "max": 24576 },
            "specialValues": [
              { "label": "Auto", "value": -1 },
              { "label": "Off", "value": 0 }
            ]
          },
          "api": { "path": "thinkingConfig.thinkingBudget" }
        },
        "includeThoughts": {
          "ui": { "type": "boolean", "label": "Include Thoughts" },
          "api": { "path": "thinkingConfig.includeThoughts" }
        }
      }
    }
  ]
}
