{
  "provider": "gemini",
  "defaults": {
    "features": {
      "systemInstruction": true
    },
    "parameters": {
      "temperature": {
        "type": "number",
        "label": "Temperature",
        "range": { "min": 0, "max": 2, "step": 0.1 }
      },
      "topP": {
        "type": "number",
        "label": "Top P",
        "range": { "min": 0, "max": 1, "step": 0.01 }
      }
    }
  },
  "models": [
    {
      "modelQuery": "image",
      "features": {
        "systemInstruction": false,
        "tools": false,
        "imageConfigParams": ["aspectRatio", "imageSize", "personGeneration"]
      },
      "parameters": {
        "temperature": null,
        "topP": null,
        "aspectRatio": {
          "type": "enum",
          "label": "Aspect Ratio",
          "options": [
            { "label": "1:1",  "value": "1:1"  },
            { "label": "3:4",  "value": "3:4"  },
            { "label": "4:3",  "value": "4:3"  },
            { "label": "9:16", "value": "9:16" },
            { "label": "16:9", "value": "16:9" },
            { "label": "2:3",  "value": "2:3"  },
            { "label": "3:2",  "value": "3:2"  },
            { "label": "21:9", "value": "21:9" }
          ]
        },
        "imageSize": {
          "type": "enum",
          "label": "Image Size",
          "options": [
            { "label": "1K (Default)", "value": "1K" },
            { "label": "2K",           "value": "2K" },
            { "label": "4K",           "value": "4K" }
          ]
        },
        "personGeneration": {
          "type": "enum",
          "label": "Person Generation",
