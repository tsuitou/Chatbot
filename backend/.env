ALLOWED_ORIGINS=
DEFAULT_MODEL=gemini-3.6-flash
GEMINI_MODEL_FILTER=gemini-2.5, gemini-3
CLAUDE_MODEL_FILTER=claude
SYSTEM_INSTRUCTION_MODE=merge
MAX_UPLOAD_FILE_SIZE=20MB
OPENROUTER_MODELS=deepseek/deepseek-v4-pro
# Optional app-identification headers sent to OpenRouter:
#OPENROUTER_APP_URL=https://your.app
#OPENROUTER_APP_TITLE=Your App Name
#OPENAI_COMPAT_CONFIG=./openai-endpoints.json