ALLOWED_ORIGINS=
DEFAULT_MODEL=gemini-3.5-flash
MODEL_FILTER=gemini-2.5, gemini-3, claude, qwen, minimax
SYSTEM_INSTRUCTION_MODE=merge
MAX_UPLOAD_FILE_SIZE=20MB
OPENROUTER_MODELS=qwen/qwen3.7-plus, minimax/minimax-m3
# Optional app-identification headers sent to OpenRouter:
#OPENROUTER_APP_URL=https://your.app
#OPENROUTER_APP_TITLE=Your App Name
