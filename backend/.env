ALLOWED_ORIGINS=
DEFAULT_MODEL=gemini-3.5-flash
MODEL_FILTER=gemini-2.5, gemini-3, claude, 3.7, m3, v4, n2, v2.5, k2.7
SYSTEM_INSTRUCTION_MODE=merge
MAX_UPLOAD_FILE_SIZE=20MB
OPENROUTER_MODELS=qwen/qwen3.7-max, qwen/qwen3.7-plus, minimax/minimax-m3, stepfun/step-3.7-flash, deepseek/deepseek-v4-pro, nex-agi/nex-n2-pro:free, xiaomi/mimo-v2.5, moonshotai/kimi-k2.7-code
# Optional app-identification headers sent to OpenRouter:
#OPENROUTER_APP_URL=https://your.app
#OPENROUTER_APP_TITLE=Your App Name
